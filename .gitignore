# Dependencies
node_modules/
**/node_modules/

# Runtime database (SQLite)
#   The live DB (data/chhaperia.db) IS committed so deploys/clones start
#   from the real data. Transient WAL/SHM and any other .db files stay ignored.
*.db
*.db-wal
*.db-shm
*.sqlite
!data/chhaperia.db

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# Logs / temp
*.log
npm-debug.log*
/tmp/
*.tmp

# Local scratch / parsing helpers (not part of the app)
parse*.py
sample_colors.py
*_home.html
prod_*.html
homepage.html
tapes_home.html
state_check.json
rt*.json

# Build artifacts
dist/
build/

# Local DB backups & test copies (safety snapshots, not part of the app)
_backup/
_testdata/

# Env
.env
.env.local
